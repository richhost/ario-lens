{
	"name": "ario-lens",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "oxfmt --check .",
		"format": "oxfmt --write .",
		"gen": "wrangler types",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:local": "bunx wrangler d1 migrations apply DB --local",
		"db:remote": "bunx wrangler d1 migrations apply DB --remote",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@ethercorps/sveltekit-og": "^4.2.1",
		"@internationalized/date": "^3.12.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tabler/icons-svelte-runes": "^3.44.0",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/svelte-form": "^1.33.0",
		"@types/node": "^24.13.2",
		"better-auth": "~1.4.22",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"exifreader": "^4.41.0",
		"nanoid": "^5.1.11",
		"oxfmt": "^0.54.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"valibot": "^1.4.1",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^8.0.16",
		"vite-plugin-devtools-json": "^1.0.0",
		"wrangler": "^4.100.0"
	}
}
